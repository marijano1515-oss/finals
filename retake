<!DOCTYPE html>
<html lang="ka">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Todo</title>
<style>
  body{
     font-family: system-ui, sans-serif;
     max-width: 420px;
     margin: 40px auto;
     padding: 0 16px;
     line-height: 1.5;
  }
  h1{
    font-size: 1.4rem;
  }
  #advice-box {
    background: #f3f4f6;
    border-left: 3px solid #6b7280;
    padding: 8px 12px;
    margin-bottom: 12px;
  }
  #advice {
    font-style: italic;
    min-height: 1.5em;
    display: block;
    margin-bottom: 8px;
  }
  #new-advice {
    border: none;
    background: #6b7280;
    color: white;
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.85rem;
  }
  #new-advice:hover { background: #4b5563; }

  .add-form { display: flex; gap: 8px; margin-bottom: 16px; }
  #todo-input { flex: 1; padding: 6px 8px; }
  .add-form button {
    padding: 6px 12px;
    border: none;
    background: #2563eb;
    color: white;
    border-radius: 4px;
    cursor: pointer;
  }

  ul { list-style: none; padding: 0; }
  li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid #eee;
  }

  .mark-btn {
    border: 1px solid #9ca3af;
    background: white;
    color: #9ca3af;
    width: 20px;
    height: 20px;
    min-width: 20px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    line-height: 1;
    padding: 0;
  }
  li.done .mark-btn {
    background: #22c55e;
    border-color: #22c55e;
    color: white;
  }

  .text { flex: 1; cursor: pointer; }
  li.done .text { text-decoration: line-through; color: #22c55e; }

  .delete-btn {
    border: none;
    background: none;
    color: #ef4444;
    cursor: pointer;
    font-size: 1rem;
  }
</style>
</head>
<body>

<h1>ჩემი Todo სია</h1>

<div id="advice-box">
  <span id="advice">loading...</span>
  <button id="new-advice">New advice</button>
</div>

<form id="add-form" class="add-form">
  <input id="todo-input" type="text" placeholder="დაამატე დავალება...">
  <button type="submit">დამატება</button>
</form>

<ul id="list"></ul>

<script>
let todos = [];
let nextId = 1;
const listEl = document.getElementById('list');
const formEl = document.getElementById('add-form');
const inputEl = document.getElementById('todo-input');
const adviceEl = document.getElementById('advice');

function render(){
    listEl.innerHTML = '';
    todos.forEach(todo => {
        const li = document.createElement('li');
        li.className = todo.done ? 'done' : '';

        const markBtn = document.createElement('button');
        markBtn.className = 'mark-btn';
        markBtn.textContent = '✓';
        markBtn.title = 'დავალება დასრულებულია';
        markBtn.addEventListener('click', () => toggle(todo.id));

        const text = document.createElement('span');
        text.className = 'text';
        text.textContent = todo.text;
        text.addEventListener('click', () => toggle(todo.id));

        const del = document.createElement('button');
        del.className = 'delete-btn';
        del.textContent = 'X';
        del.addEventListener('click', () => remove(todo.id));

        li.append(markBtn, text, del);
        listEl.appendChild(li);
    });
}

formEl.addEventListener('submit', e => {
    e.preventDefault();
    const text = inputEl.value.trim();
    if (text === '') return; // ignore empty input
    todos.push({ id: nextId++, text, done: false });
    inputEl.value = ''; // clear the input
    render();
});

function toggle(id) {
    const todo = todos.find(t => t.id === id);
    if (todo) todo.done = !todo.done;
    render();
}

function remove(id) {
    if (!confirm('დარწმუნებული ხართ?')) return; // only delete on OK
    todos = todos.filter(t => t.id !== id);
    render();
}

async function loadAdvice() {
    adviceEl.textContent = 'loading...';
    try {
      const res = await fetch('https://api.adviceslip.com/advice');
      if (!res.ok) throw new Error('Network error');
      const data = await res.json();
      adviceEl.textContent = data.slip.advice;
      console.log(data);
    } catch (err) {
      adviceEl.textContent = 'loading could not happen';
    }
}

document.getElementById('new-advice').addEventListener('click', loadAdvice);
loadAdvice();
render();
</script>
</body>
</html>
